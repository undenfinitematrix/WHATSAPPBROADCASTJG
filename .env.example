# ========================================
# META WHATSAPP CONFIGURATION
# ========================================
# Get these from Meta Business Manager
META_ACCESS_TOKEN=your_system_user_token_here
META_WABA_ID=your_whatsapp_business_account_id_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_APP_SECRET=your_app_secret_here
META_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_token_here
META_API_VERSION=v21.0
META_API_BASE_URL=https://graph.facebook.com

# ========================================
# WEBHOOK & SERVER CONFIGURATION
# ========================================
# Get this from Vercel after deployment
WEBHOOK_URL=https://your-vercel-url.vercel.app/api/broadcasts/webhook

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MySQL via phpMyAdmin at localhost
# Format: mysql+aiomysql://username:password@host:port/database
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/aerochat

# ========================================
# ENVIRONMENT
# ========================================
ENV=development
DEBUG=true
